generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Use a *direct/non-pooling* connection for Prisma CLI operations (db push/migrate).
  // In Vercel + Supabase integration, you can set DIRECT_URL = POSTGRES_URL_NON_POOLING.
  directUrl = env("DIRECT_URL")
}

model Store {
  id             String   @id @default(cuid())
  organizationId String?
  franchiseId    String?
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  franchise    Franchise?    @relation(fields: [franchiseId], references: [id])

  products       Product[]
  movements      InventoryMovement[]
  purchaseDrafts PurchaseDraft[]
  purchaseOrders PurchaseOrder[]

  // Tickets / ventas importadas
  ticketImports TicketImportBatch[]
  tickets       Ticket[]
  leads         Lead[]
  leadEvents    LeadEvent[]
  followUpTasks FollowUpTask[]
  bookings      Booking[]
  activityLogs  ActivityLog[]

  // Aliases para matcheo (códigos/nombres) desde POS
  productAliases ProductAlias[]

  // Taxonomías por ámbito (PRODUCT, SUPPLIER, ORDER, etc.)
  categories Category[]

  // Auditoría (acciones del Copiloto y del usuario)
  auditLogs          AuditLog[]
  memberships        StoreMember[]
  channelConnections ChannelConnection[]
  inboundEvents      InboundEvent[]
  AvailabilityRule   AvailabilityRule[]

  @@index([organizationId])
  @@index([franchiseId])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  createdAt DateTime @default(now())

  franchises Franchise[]
  stores     Store[]
  members    OrgMember[]
}

model Franchise {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  stores       Store[]

  @@index([organizationId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  createdAt    DateTime @default(now())

  sessions         Session[]
  accounts         Account[]
  orgMemberships   OrgMember[]
  storeMemberships StoreMember[]
}

model OrgMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model StoreMember {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  role      String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
  @@index([storeId])
}

model Lead {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  name     String
  contact  String
  summary  String?
  source   String?
  priority String  @default("MEDIUM")
  status   String  @default("NEW")
  nextStep String?

  lastActivityAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  events        LeadEvent[]
  followUpTasks FollowUpTask[]
  bookings      Booking[]
  activityLogs  ActivityLog[]

  @@index([storeId, status])
  @@index([storeId, lastActivityAt])
}

model LeadEvent {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  type    String
  message String

  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@index([storeId, createdAt])
}

enum FollowUpTaskStatus {
  OPEN
  CLOSED
}

model FollowUpTask {
  id String @id @default(cuid())

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  taskType String
  priority String             @default("MEDIUM")
  dueAt    DateTime
  status   FollowUpTaskStatus @default(OPEN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  @@index([storeId, status, dueAt])
  @@index([leadId, taskType, status])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id])

  contactId String?

  startsAt DateTime
  endsAt   DateTime
  status   BookingStatus @default(PENDING)
  notes    String?

  confirmedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([storeId, startsAt])
  @@index([storeId, status, startsAt])
  @@index([leadId])
  @@index([contactId])
}

model AvailabilityRule {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, dayOfWeek, isActive])
}

model ActivityLog {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  leadId    String?
  bookingId String?

  type    String
  message String
  payload String?

  createdAt DateTime @default(now())
  Lead      Lead?    @relation(fields: [leadId], references: [id])

  @@index([storeId, createdAt])
  @@index([leadId, createdAt])
  @@index([bookingId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       Product[]
  purchaseDrafts PurchaseDraft[]
  purchaseOrders PurchaseOrder[]
}

model Product {
  id       String  @id @default(cuid())
  name     String
  sku      String?
  category String? // legacy (texto libre)

  categoryId  String?
  categoryRef Category? @relation(fields: [categoryId], references: [id])

  unit  String @default("unidad")
  cost  Float  @default(0)
  price Float  @default(0)

  // Configuración de reposición (por producto)
  stockMin     Int @default(0)
  leadTimeDays Int @default(3) // días que tarda el proveedor
  coverageDays Int @default(14) // días que querés cubrir (post-llegada)
  safetyStock  Int @default(0) // unidades extra (colchón)

  currentStock Int @default(0)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  movements          InventoryMovement[]
  purchaseOrderItems PurchaseOrderItem[]

  // Ventas importadas
  ticketLines TicketLine[]

  // Alias para matcheo desde POS
  aliases ProductAlias[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([supplierId])
  @@index([categoryId])
}

model ProductAlias {
  id String @id @default(cuid())

  // CODE: código/sku/barcode del POS
  // NAME: nombre normalizado del POS
  kind String
  key  String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([storeId, kind, key])
  @@index([storeId])
  @@index([productId])
}

model Category {
  id    String  @id @default(cuid())
  scope String // PRODUCT | SUPPLIER | ORDER | TICKET | ...
  name  String
  slug  String
  color String?
  icon  String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  // relaciones por ámbito (por ahora: Productos)
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, scope, slug])
  @@index([storeId])
  @@index([scope])
}

model InventoryMovement {
  id String @id @default(cuid())

  // SQLite no soporta enums en Prisma: guardamos el tipo como string validado en la app (IN | OUT | ADJUST).
  type String
  qty  Int
  note String?

  productId String
  product   Product @relation(fields: [productId], references: [id])

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  // Si el movimiento fue generado por una importación de tickets,
  // lo linkeamos al lote para poder auditar y (si no hay movimientos posteriores) deshacer.
  importBatchId String?
  importBatch   TicketImportBatch? @relation(fields: [importBatchId], references: [id])

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([storeId])
  @@index([importBatchId])
}

model PurchaseDraft {
  id        String   @id @default(cuid())
  title     String   @default("Borrador")
  message   String
  csv       String
  itemCount Int      @default(0)
  createdAt DateTime @default(now())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  @@index([storeId])
  @@index([supplierId])
}

model PurchaseOrder {
  id     String  @id @default(cuid())
  title  String  @default("Orden de compra")
  status String  @default("DRAFT") // DRAFT | SENT | PARTIAL | RECEIVED | CANCELED
  notes  String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  receivedAt DateTime?

  items PurchaseOrderItem[]

  @@index([storeId])
  @@index([supplierId])
}

model PurchaseOrderItem {
  id String @id @default(cuid())

  orderId String
  order   PurchaseOrder @relation(fields: [orderId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  qtyOrdered  Int
  qtyReceived Int @default(0)

  unitCost Float?
  note     String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

model TicketImportBatch {
  id       String  @id @default(cuid())
  source   String  @default("CSV")
  fileName String?
  notes    String?

  ticketsCount    Int @default(0)
  linesCount      Int @default(0)
  movementsCount  Int @default(0)
  skippedCount    Int @default(0)
  duplicatesCount Int @default(0)
  errorCount      Int @default(0)
  unmatchedLines  Int @default(0)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  importedAt DateTime @default(now())

  tickets   Ticket[]
  movements InventoryMovement[]

  @@index([storeId])
}

model Ticket {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  batchId String?
  batch   TicketImportBatch? @relation(fields: [batchId], references: [id])

  externalId String?
  issuedAt   DateTime?
  total      Float?

  // hash para evitar duplicados incluso si no hay externalId
  hash String

  createdAt DateTime @default(now())

  lines TicketLine[]

  @@unique([storeId, hash])
  @@index([storeId])
  @@index([batchId])
}

model TicketLine {
  id String @id @default(cuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  // datos crudos desde el POS
  sku       String?
  name      String?
  qty       Int
  unitPrice Float?
  lineTotal Float?

  matchedBy  String? // ALIAS_CODE | ALIAS_NAME | SKU | NAME | MANUAL
  resolvedAt DateTime?

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([productId])
}

model AuditLog {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  role      String
  action    String
  entity    String?
  entityId  String?
  payload   String?
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([storeId])
  @@index([action])
  @@index([createdAt])
}

enum InboundEventStatus {
  PENDING
  PROCESSED
  FAILED
}

model ChannelConnection {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  provider          String
  externalAccountId String
  metadata          String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  inboundEvents InboundEvent[]

  @@unique([provider, externalAccountId])
  @@index([storeId, provider])
}

model InboundEvent {
  id String @id @default(cuid())

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  channelConnectionId String?
  channelConnection   ChannelConnection? @relation(fields: [channelConnectionId], references: [id])

  provider   String
  eventType  String?
  payload    String
  receivedAt DateTime           @default(now())
  status     InboundEventStatus @default(PENDING)
  attempts   Int                @default(0)
  lastError  String?

  @@index([storeId, provider, status])
  @@index([channelConnectionId])
}
